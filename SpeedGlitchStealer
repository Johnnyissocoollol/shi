sliderBtn.Position = UDim2.new(0, -12, 0.5, -12)
sliderBtn.BackgroundColor3 = Color3.fromRGB(180, 180, 190)
sliderBtn.BorderSizePixel = 0
sliderBtn.Parent = sliderTrack
Instance.new("UICorner", sliderBtn).CornerRadius = UDim.new(1, 0)

local dragStart, startPos
local isDraggingTitle = false

title.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.Touch then
		isDraggingTitle = true
		dragStart = input.Position
		startPos = frame.Position
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if isDraggingTitle and input.UserInputType == Enum.UserInputType.Touch then
		local delta = input.Position - dragStart
		frame.Position = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset + delta.Y
		)
	end
	
	if sliding and input.UserInputType == Enum.UserInputType.Touch then
		handleSlider(input)
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.Touch then
		isDraggingTitle = false
		sliding = false
	end
end)

local function updateToggle()
	if enabled then
		switchFrame.BackgroundColor3 = Color3.fromRGB(100, 100, 110)
		switchCircle.Position = UDim2.new(0, 20, 0.5, -9)
	else
		switchFrame.BackgroundColor3 = Color3.fromRGB(60, 60, 70)
		switchCircle.Position = UDim2.new(0, 2, 0.5, -9)
	end
end

local function toggle()
	enabled = not enabled

	if enabled then
		conn = RunService.Heartbeat:Connect(function()
			local char = localplayer.Character
			if not char then return end
			local hum = char:FindFirstChildOfClass("Humanoid")
			if not hum then return end

			local state = hum:GetState()
			local air = state == Enum.HumanoidStateType.Jumping
				or state == Enum.HumanoidStateType.Freefall
				or state == Enum.HumanoidStateType.FallingDown

			if air and hum.MoveDirection.Magnitude > 0 then
				hum.WalkSpeed = speed
			else
				hum.WalkSpeed = 16
			end
		end)
	else
		if conn then conn:Disconnect() conn = nil end
		local char = localplayer.Character
		if char then
			local hum = char:FindFirstChildOfClass("Humanoid")
			if hum then hum.WalkSpeed = 16 end
		end
	end

	updateToggle()
end

switchFrame.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.Touch then
		toggle()
	end
end)

local function updateSlider(value)
	local percent = value / 200
	sliderFill.Size = UDim2.new(percent, 0, 1, 0)
	sliderBtn.Position = UDim2.new(percent, -12, 0.5, -12)
	speedLabel.Text = tostring(value)
	speed = value
end

local function handleSlider(input)
	task.wait()

	local trackPos = sliderTrack.AbsolutePosition.X
	local trackSize = sliderTrack.AbsoluteSize.X

	if trackSize == 0 then return end

	local pos = input.Position.X - trackPos
	local percent = math.clamp(pos / trackSize, 0, 1)
	local value = math.floor(percent * 200 + 0.5)
	value = math.max(20, math.min(200, value))
	updateSlider(value)
end

sliderTouchArea.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.Touch then
		sliding = true
		handleSlider(input)
	end
end)

sliderBtn.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.Touch then
		sliding = true
		handleSlider(input)
	end
end)

localplayer.CharacterAdded:Connect(function()
	task.wait(0.5)
	local char = localplayer.Character
	if char then
		local hum = char:FindFirstChildOfClass("Humanoid")
		if hum then hum.WalkSpeed = 16 end
	end
end)

updateSlider(65)
updateToggle()
